{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/dashboard",
      "dest": "/api/dashboard.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
