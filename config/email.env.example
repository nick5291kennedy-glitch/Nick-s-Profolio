# Then fill in your SMTP details to enable summary emails.

MARKET_SUMMARY_EMAIL_TO=you@example.com
MARKET_SUMMARY_EMAIL_FROM=you@example.com
MARKET_SUMMARY_SMTP_HOST=smtp.example.com
MARKET_SUMMARY_SMTP_PORT=465
MARKET_SUMMARY_SMTP_USERNAME=you@example.com
MARKET_SUMMARY_SMTP_PASSWORD=your_app_password_or_smtp_password
MARKET_SUMMARY_SMTP_SSL=true
